# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public
NEXT_PUBLIC_BASE_URL=https://gatetest.ai
NEXT_PUBLIC_APP_VERSION=1.0.0

# Gluecron (primary git host)
GLUECRON_BASE_URL=https://gluecron.com
GLUECRON_API_TOKEN=glc_...
GLUECRON_API_URL=https://gluecron.com/api
GLUECRON_TOKEN=glc_...

# GitHub App (dual-host — GitHub Marketplace distribution)
GATETEST_APP_ID=
GATETEST_PRIVATE_KEY=
GATETEST_WEBHOOK_SECRET=
GATETEST_GITHUB_TOKEN=
GIT_HOST=github

# GitHub OAuth (admin panel + customer login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
SESSION_SECRET=

# Admin
GATETEST_ADMIN_PASSWORD=change_me_before_deploy
GATETEST_ADMIN_USERNAMES=
GATETEST_API_KEY=
# Vercel Cron auth — set to any random secret; Vercel sends it as "Authorization: Bearer <value>"
# Without this, /api/watches/tick and /api/scan/worker/tick are open to any caller in production
CRON_SECRET=

# AI
ANTHROPIC_API_KEY=

# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Build metadata (set by CI — no value needed locally)
APP_VERSION=
GIT_COMMIT=

# SSH healing (optional — remote server access for auto-fix)
GATETEST_SSH_HOST=
GATETEST_SSH_PORT=22
GATETEST_SSH_USER=
GATETEST_SSH_PASSWORD=
GATETEST_SSH_KEY=
