{
  "name": "gatetest",
  "version": "1.0.1",
  "description": "GateTest — the unified quality gate for AI-generated code. 90 modules: security, accessibility, performance, AI code review, and auto-fix.",
  "main": "src/index.js",
  "bin": {
    "gatetest": "./bin/gatetest.js",
    "gatetest-mcp": "./bin/gatetest-mcp.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "app": "node src/app-server.js",
    "gatetest": "node bin/gatetest.js",
    "gatetest:full": "node bin/gatetest.js --suite full",
    "gatetest:quick": "node bin/gatetest.js --suite quick",
    "gatetest:security": "node bin/gatetest.js --module security",
    "gatetest:visual": "node bin/gatetest.js --module visual",
    "gatetest:a11y": "node bin/gatetest.js --module accessibility",
    "gatetest:perf": "node bin/gatetest.js --module performance",
    "gatetest:seo": "node bin/gatetest.js --module seo",
    "gatetest:links": "node bin/gatetest.js --module links",
    "gatetest:scan": "node bin/gatetest.js --mode scan",
    "gatetest:report": "node bin/gatetest.js --report",
    "lint": "eslint src/ --ext .js",
    "precommit": "node src/hooks/pre-commit.js",
    "prepush": "node src/hooks/pre-push.js",
    "prepublishOnly": "node bin/gatetest.js --list >/dev/null && node --test tests/*.test.js"
  },
  "keywords": [
    "testing",
    "qa",
    "quality-assurance",
    "code-quality",
    "static-analysis",
    "security",
    "accessibility",
    "performance",
    "visual-regression",
    "seo",
    "linter",
    "auto-fix",
    "ai-code-review",
    "claude",
    "ci-cd",
    "github-actions",
    "sarif",
    "mutation-testing",
    "chaos-testing",
    "gatetest"
  ],
  "homepage": "https://gatetest.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ccantynz-alt/gatetest.git"
  },
  "bugs": {
    "url": "https://github.com/ccantynz-alt/gatetest/issues"
  },
  "author": {
    "name": "GateTest",
    "email": "hello@gatetest.ai",
    "url": "https://gatetest.ai"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
